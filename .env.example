# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cbt_apoteker

# Optional override for PostgreSQL SSL negotiation (`true` or `false`)
DATABASE_SSL=false

# Secret key untuk verifikasi JWT access token
JWT_SECRET=replace_with_a_strong_random_secret

# Optional email delivery via Resend
RESEND_API_KEY=
EMAIL_FROM=CBT Apoteker <no-reply@your-domain.com>

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_NOTIFICATION_URL=
MIDTRANS_FINISH_URL=
MIDTRANS_UNFINISH_URL=
MIDTRANS_ERROR_URL=

# Optional (default: 3001)
PORT=3001
