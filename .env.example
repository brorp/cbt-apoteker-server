# Shared PostgreSQL settings for Docker Compose and backend.
# Prefer setting these so DB container and app use the same credentials.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=cbt_apoteker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional explicit PostgreSQL connection string.
# If omitted, the backend and Drizzle will build it from POSTGRES_* above.
DATABASE_URL=

# Optional override for PostgreSQL SSL negotiation (`true` or `false`)
DATABASE_SSL=false

# Secret key untuk verifikasi JWT access token
JWT_SECRET=replace_with_a_strong_random_secret
EMAIL_OTP_SECRET=
AUTH_FLOW_SECRET=
GOOGLE_CLIENT_ID=

# Optional email delivery via Resend
RESEND_API_KEY=
EMAIL_FROM="CBT Apoteker <no-reply@your-domain.com>"

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_NOTIFICATION_URL=
MIDTRANS_FINISH_URL=
MIDTRANS_UNFINISH_URL=
MIDTRANS_ERROR_URL=

# Optional (default: 3001)
PORT=3001
